---
import experience from '../data/experience.json';
---

<section id="experience" class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Trayectoria</span>
      <h2 class="section-title">Experiencia <span class="gradient-text">Profesional</span></h2>
      <p class="section-subtitle">Mi historial de trabajo y los logros que me hacen destacar</p>
    </div>

    <div class="timeline">
      {experience.map((job, index) => (
        <div class="timeline-item">
          <div class="timeline-dot" aria-hidden="true">
            {job.current && <span class="dot-pulse"></span>}
          </div>
          <div class="timeline-line" aria-hidden="true"></div>

          <article class="timeline-card card">
            <div class="job-header">
              <div class="job-meta">
                <h3 class="job-company">{job.company}</h3>
                <p class="job-role">{job.role}</p>
              </div>
              <div class="job-badge-group">
                {job.current && <span class="badge-current">Actual</span>}
                <span class="job-dates">{job.startDate} — {job.endDate}</span>
              </div>
            </div>

            <p class="job-location">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              {job.location}
            </p>

            <ul class="job-achievements" role="list">
              {job.achievements.map(achievement => (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {achievement}
                </li>
              ))}
            </ul>

            <div class="job-techs">
              {job.technologies.map(tech => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          </article>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 30px 1fr;
    gap: 0 1.5rem;
    align-items: start;
  }

  .timeline-dot {
    position: relative;
    width: 30px;
    height: 30px;
    background: var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1.5rem;
    z-index: 1;
  }

  .dot-pulse {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--color-accent);
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping {
    75%, 100% { transform: scale(1.8); opacity: 0; }
  }

  .timeline-line {
    grid-column: 1;
    width: 2px;
    background: var(--color-border);
    margin: 0 auto;
    flex: 1;
    min-height: 2rem;
    align-self: stretch;
  }

  .timeline-card { grid-column: 2; grid-row: 1 / 3; }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .job-company {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .job-role {
    font-size: 0.92rem;
    color: var(--color-accent-2);
    font-weight: 600;
    margin-top: 0.15rem;
  }

  .job-badge-group {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .badge-current {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 700;
    background: rgba(52, 211, 153, 0.15);
    color: var(--color-success);
    border: 1px solid rgba(52, 211, 153, 0.3);
  }

  .job-dates {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .job-location {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .job-achievements {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .job-achievements li {
    display: flex;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .check-icon {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .job-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @media (max-width: 600px) {
    .timeline-item { grid-template-columns: 1fr; }
    .timeline-dot, .timeline-line { display: none; }
    .timeline-card { grid-column: 1; grid-row: 1; }
    .job-badge-group { align-items: flex-start; }
  }
</style>
