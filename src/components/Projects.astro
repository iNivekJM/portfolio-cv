---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<section id="projects" class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Portafolio</span>
      <h2 class="section-title">Proyectos <span class="gradient-text">Destacados</span></h2>
      <p class="section-subtitle">Soluciones reales desarrolladas a lo largo de mi carrera</p>
    </div>

    <div class="projects-grid">
      {projects.map((project, i) => (
        <article class={`project-card card ${project.data.featured ? 'featured' : ''}`}>
          <div class="project-body">
            {project.data.featured && (
              <span class="featured-badge">⭐ Destacado</span>
            )}

            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-desc">{project.data.description}</p>

            <div class="project-techs">
              {project.data.techs.map(tech => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          </div>

          <div class="project-footer">
            {project.data.repoUrl && (
              <a
                href={project.data.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary proj-btn"
                aria-label={`Ver repositorio de ${project.data.title}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                Repositorio
              </a>
            )}
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary proj-btn"
                aria-label={`Ver demo de ${project.data.title}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                Ver demo
              </a>
            )}
            {!project.data.repoUrl && !project.data.liveUrl && (
              <span class="private-badge">🔒 Proyecto privado</span>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Add project hint -->
    <div class="add-project-hint">
      <p>
        ¿Quieres agregar un proyecto? Crea un archivo Markdown en
        <code>src/content/projects/mi-proyecto.md</code>
      </p>
    </div>
  </div>
</section>

<style>
  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }

  .project-card.featured {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent), 0 8px 30px var(--color-accent-glow);
  }

  .project-card.featured::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-2));
    border-radius: 1rem 1rem 0 0;
  }

  .featured-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent-2);
    margin-bottom: 0.25rem;
  }

  .project-body { flex: 1; display: flex; flex-direction: column; gap: 0.75rem; }

  .project-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .project-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
  }

  .project-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .project-footer {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .proj-btn {
    flex: 1;
    justify-content: center;
    padding-block: 0.6rem;
    font-size: 0.88rem;
  }

  .private-badge {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .add-project-hint {
    margin-top: 3rem;
    text-align: center;
    padding: 1.25rem 2rem;
    border: 1px dashed var(--color-border);
    border-radius: 1rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }

  .add-project-hint code {
    font-family: monospace;
    background: rgba(108, 99, 255, 0.1);
    color: var(--color-accent-2);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
  }
</style>
