---
import profileEs from '../data/profile.json';
import profileEn from '../data/profile_en.json';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

// Importar iconos como string (RAW)
import mailIcon from '../icons/mail.svg?raw';
import whatsappIcon from '../icons/whatsapp.svg?raw';
import linkedinIcon from '../icons/linkedin.svg?raw';
import githubIcon from '../icons/github.svg?raw';

const lang = getLangFromUrl(Astro.url);
const profile = lang === 'en' ? profileEn : profileEs;
const t = useTranslations(lang);
---

<section id="contact" class="section section-alt">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{t('nav.contact')}</span>
      <h2 class="section-title">{t('contact.title').split(' ')[0]} <span class="gradient-text">{t('contact.title').split(' ').slice(1).join(' ')}</span></h2>
      <p class="section-subtitle">{t('contact.subtitle')}</p>
    </div>

    <div class="contact-grid">
      <!-- Info -->
      <div class="contact-info">
        <p class="contact-message">{profile.bio}</p>

        <div class="contact-links">
          <a href={`mailto:${profile.email}`} class="contact-link-item">
            <span class="link-icon" aria-hidden="true">
              <Fragment set:html={mailIcon} />
            </span>
            <div>
              <span class="link-label">{t('contact.email')}</span>
              <span class="link-value">{profile.email}</span>
            </div>
          </a>

          <a href={profile.phone} class="contact-link-item">
            <span class="link-icon" aria-hidden="true">
              <Fragment set:html={whatsappIcon} />
            </span>
            <div>
              <span class="link-label">Whatsapp</span>
              <span class="link-value">{profile.phoneText}</span>
            </div>
          </a>

          <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="contact-link-item">
            <span class="link-icon" aria-hidden="true">
              <Fragment set:html={linkedinIcon} />
            </span>
            <div>
              <span class="link-label">LinkedIn</span>
              <span class="link-value">linkedin.com/in/iNivekJM</span>
            </div>
          </a>

          <a href={profile.github} target="_blank" rel="noopener noreferrer" class="contact-link-item">
            <span class="link-icon" aria-hidden="true">
              <Fragment set:html={githubIcon} />
            </span>
            <div>
              <span class="link-label">GitHub</span>
              <span class="link-value">github.com/iNivekJM</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Form -->
      <form id="contact-form" class="contact-form card" novalidate data-netlify="true" name="contact">
        <input type="hidden" name="form-name" value="contact" />
        <div class="form-group">
          <label for="cf-name">{t('contact.name')}</label>
          <input type="text" id="cf-name" name="name" placeholder="Kevin Ariza" required autocomplete="name" aria-describedby="cf-name-error" />
          <span id="cf-name-error" class="error-message" aria-live="polite"></span>
        </div>

        <div class="form-group">
          <label for="cf-email">{t('contact.email')}</label>
          <input type="email" id="cf-email" name="email" placeholder="Kevin@gmail.com" required autocomplete="email" aria-describedby="cf-email-error" />
          <span id="cf-email-error" class="error-message" aria-live="polite"></span>
        </div>

        <div class="form-group">
          <label for="cf-subject">{t('contact.subject')}</label>
          <input type="text" id="cf-subject" name="subject" placeholder={t('contact.placeholder.subject')} />
        </div>

        <div class="form-group">
          <label for="cf-message">{t('contact.message')}</label>
          <textarea id="cf-message" name="message" rows="5" placeholder={t('contact.placeholder.message')} required aria-describedby="cf-message-error"></textarea>
          <span id="cf-message-error" class="error-message" aria-live="polite"></span>
        </div>

        <button type="submit" class="btn btn-primary submit-btn" id="submit-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          <span id="submit-text">{t('contact.submit')}</span>
        </button>

        <p id="form-status" class="form-status" role="alert" aria-live="polite" data-success={t('contact.success')} data-error={t('contact.error')} data-sending={t('contact.sending')}></p>
      </form>
    </div>
  </div>
</section>

<style>
  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .contact-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid { grid-template-columns: 1fr 1.2fr; }
  }

  .contact-message {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-link-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    padding: 1rem 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .contact-link-item:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
  }

  .link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: rgba(108, 99, 255, 0.1);
    color: var(--color-accent);
    border-radius: 50%;
    flex-shrink: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .contact-link-item:hover .link-icon {
    background: var(--color-accent);
    color: #fff;
    transform: scale(1.1);
  }

  .link-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .contact-link-item > div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .link-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .link-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.625rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    resize: vertical;
    outline: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder { color: var(--color-text-muted); }

  .submit-btn { justify-content: center; }

  .form-status {
    text-align: center;
    font-size: 0.88rem;
    min-height: 1.2em;
  }

  .form-status.success { color: var(--color-success); }
  .form-status.error { color: #f87171; }

  .error-message {
    font-size: 0.75rem;
    color: #f87171;
    min-height: 1rem;
    margin-top: 0.25rem;
  }

  input[aria-invalid="true"],
  textarea[aria-invalid="true"] {
    border-color: #f87171;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;

  const validateField = (input: HTMLInputElement | HTMLTextAreaElement) => {
    const errorSpan = document.getElementById(`${input.id}-error`) as HTMLElement;
    if (!input.validity.valid) {
      input.setAttribute('aria-invalid', 'true');
      errorSpan.textContent = input.validationMessage;
      return false;
    }
    input.setAttribute('aria-invalid', 'false');
    errorSpan.textContent = '';
    return true;
  };

  form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach(input => {
    input.addEventListener('blur', () => validateField(input));
    input.addEventListener('input', () => {
      if (input.getAttribute('aria-invalid') === 'true') {
        validateField(input);
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    let isValid = true;
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[required], textarea[required]').forEach(input => {
      if (!validateField(input)) isValid = false;
    });
    
    if (!isValid) return;

    btn.disabled = true;
    const originalContent = btn.innerHTML;
    const submitText = document.getElementById('submit-text')!;
    submitText.textContent = status.dataset.sending || 'Enviando...';

    const formData = new FormData(form);
    
    try {
      const response = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(formData as unknown as Record<string, string>).toString(),
      });

      if (response.ok) {
        status.textContent = status.dataset.success || '✅ ¡Mensaje enviado!';
        status.className = 'form-status success';
        form.reset();
        form.querySelectorAll<HTMLInputElement>('[aria-invalid]').forEach(el => el.setAttribute('aria-invalid', 'false'));
      } else {
        throw new Error();
      }
    } catch (error) {
      status.textContent = status.dataset.error || '❌ Hubo un error.';
      status.className = 'form-status error';
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalContent;
    }
  });
</script>
