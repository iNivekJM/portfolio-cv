---
import profileEs from '../data/profile.json';
import profileEn from '../data/profile_en.json';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const profile = lang === 'en' ? profileEn : profileEs;
const cv = lang === "en" ? '../cv_EN.pdf' : 'cv_ES.pdf';

const content = {
  es: {
    availability: 'Disponible para nuevas oportunidades',
    greet: 'Hola, soy',
    btnProjects: 'Ver proyectos',
    btnContact: 'Contactar',
    btnCV: 'Descargar CV',
    stat1: 'Años de experiencia',
    stat2: 'Aplicaciones desarrolladas',
    stat3: 'Usuarios impactados',
    stat4: 'Peticiones API/día',
  },
  en: {
    availability: 'Available for new opportunities',
    greet: "Hi, I'm",
    btnProjects: 'View projects',
    btnContact: 'Contact',
    btnCV: 'Download CV',
    stat1: 'Years of experience',
    stat2: 'Applications developed',
    stat3: 'Impacted users',
    stat4: 'API requests/day',
  }
}[lang];
---

<section class="hero" aria-label="Presentación">
  <!-- Background blobs -->
  <div class="blob blob-1" aria-hidden="true"></div>
  <div class="blob blob-2" aria-hidden="true"></div>
  <div class="noise" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-content animate-fade-up">
      <span class="hero-badge">
        <span class="badge-dot" aria-hidden="true"></span>
        {content.availability}
      </span>

      <h1 class="hero-name">
        {content.greet} <span class="gradient-text">{profile.name}</span>
      </h1>

      <p class="hero-title">{profile.subtitle}</p>

      <p class="hero-bio">{profile.bio}</p>

      <div class="hero-actions">
        <a href="#projects" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          {content.btnProjects}
        </a>
        <a href="#contact" class="btn btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {content.btnContact}
        </a>
        <a href={cv} download class="btn btn-secondary" aria-label="Descargar currículum en PDF">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          {content.btnCV}
        </a>
      </div>

      <!-- Social Links -->
      <div class="hero-socials">
        <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn de Kevin Ariza">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </a>
        <a href={`mailto:${profile.email}`} class="social-link" aria-label="Enviar email a Kevin Ariza">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {profile.email}
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="hero-stats">
      <div class="stat-card animate-fade-up" style="animation-delay:0.2s">
        <span class="stat-number gradient-text">7+</span>
        <span class="stat-label">{content.stat1}</span>
      </div>
      <div class="stat-card animate-fade-up" style="animation-delay:0.35s">
        <span class="stat-number gradient-text">70+</span>
        <span class="stat-label">{content.stat2}</span>
      </div>
      <div class="stat-card animate-fade-up" style="animation-delay:0.5s">
        <span class="stat-number gradient-text">10000+</span>
        <span class="stat-label">{content.stat3}</span>
      </div>
      <div class="stat-card animate-fade-up" style="animation-delay:0.65s">
        <span class="stat-number gradient-text">50k+</span>
        <span class="stat-label">{content.stat4}</span>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <a href="#about" class="scroll-hint" aria-label="Ir a la sección sobre mí">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-block: 100px 60px;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    z-index: 0;
  }

  .blob-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(108, 99, 255, 0.4) 0%, transparent 70%);
    top: -100px; left: -150px;
    animation: float 8s ease-in-out infinite;
  }

  .blob-2 {
    width: 450px; height: 450px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.3) 0%, transparent 70%);
    bottom: -100px; right: -100px;
    animation: float 10s ease-in-out infinite reverse;
  }

  .noise {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    align-items: flex-start;
  }

  .hero-content { max-width: 720px; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: rgba(108, 99, 255, 0.08);
    color: var(--color-accent-2);
    font-size: 0.82rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.25);
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.25); }
    50%       { box-shadow: 0 0 0 6px rgba(52, 211, 153, 0.1); }
  }

  .hero-name {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  .hero-bio {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .hero-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .social-link:hover { color: var(--color-accent); }

  /* Stats */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(170px, 1fr));
    gap: 1rem;
    width: 100%;
    max-width: 420px;
    align-self: flex-start;
  }

  .stat-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: border-color 0.3s ease;
  }

  .stat-card:hover { border-color: var(--color-accent); }

  .stat-number {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-text-muted);
    animation: bounce 2s ease infinite;
    text-decoration: none;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* Responsive */
  @media (min-width: 900px) {
    .hero-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .hero-stats {
      align-self: center;
      flex-shrink: 0;
    }
  }

  @media (max-width: 480px) {
    .hero-actions { flex-direction: column; }
    .btn { justify-content: center; }
    .hero-stats { grid-template-columns: repeat(2, 1fr); max-width: 100%; }
  }
</style>
